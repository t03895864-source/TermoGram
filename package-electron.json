{
  "name": "termogram-desktop",
  "version": "1.0.0",
  "description": "TERMOGRAM Desktop Application",
  "main": "electron-main.js",
  "scripts": {
    "electron:start": "electron .",
    "electron:build": "electron-builder --win",
    "electron:build:all": "electron-builder --win --mac --linux"
  },
  "author": "TERMOGRAM Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.termogram.app",
    "productName": "TERMOGRAM",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
